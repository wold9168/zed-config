// Some example tasks for common languages.
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Go (Delve)",
    "adapter": "Delve",
    "program": "$ZED_FILE",
    "request": "launch",
    "mode": "debug",
  },
  {
    "label": "Run integration tests",
    "adapter": "Delve",
    "request": "launch",
    "mode": "test",
    "program": "$ZED_DIRNAME",
    "buildFlags": ["-tags", "integration"],
  },
  {
    "label": "Debug C (make)",
    "build": {
      "command": "make",
      "args": ["-j8"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/build/prog",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "Debug C (clang)",
    "build": {
      "command": "clang",
      "args": ["-g", "$ZED_FILE", "-o", "$ZED_DIRNAME/$ZED_STEM"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_DIRNAME/$ZED_STEM",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "Debug Modern C (clang c23)",
    "build": {
      "command": "clang",
      "args": [
        "-std=c23",
        "-Wall",
        "-lm",
        "-g",
        "$ZED_FILE",
        "-o",
        "$ZED_DIRNAME/$ZED_STEM",
      ],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_DIRNAME/$ZED_STEM",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "Debug C++ (cmake)",
    "build": {
      "command": "cmake",
      "args": ["--build", "build"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/build/main/main",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "Debug C++ (clang++)",
    "build": {
      "command": "clang++",
      "args": ["-g", "$ZED_FILE", "-o", "$ZED_DIRNAME/$ZED_STEM"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_DIRNAME/$ZED_STEM",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "adapter": "JavaScript",
    "label": "Debug JS file",
    "type": "node",
    "request": "launch",
    "program": "$ZED_FILE",
    "skipFiles": ["<node_internals>/**"],
  },
]
