  "telemetry": {
    "metrics": false,
  },
  "show_edit_predictions": true,
  "agent": {
    "default_model": {
      "provider": "deepseek",
      "model": "deepseek-reasoner",
      "enable_thinking": false
    },
    "commit_message_model": {
      "provider": "deepseek",
      "model": "deepseek-chat",
    },
    "inline_assistant_model": {
      "provider": "deepseek",
      "model": "deepseek-chat",
    },
    "default_profile": "write",
    "model_parameters": [],
  },
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
    },
    "Typst": {
      "formatter": {
        "external": {
          "command": "typstyle",
          "arguments": ["{buffer_path}"],
        },
      },
      "soft_wrap": "editor_width",
    },
    "C++": {
      "tab_size": 2,
    },
  },
  "lsp": {
    "jdtls": {
      "initialization_options": {
        "project": {
          "sourcePaths": [".", "**/src"],
        },
      },
      "settings": {
        "jdk_auto_download": false,
      },
    },
  },
  "vim_mode": false,
  "base_keymap": "VSCode",
  "ui_font_size": 16.0,
  "buffer_font_size": 18,
  "theme": {
    "mode": "light",
    "light": "One Light",
    "dark": "One Dark",
  },
  "auto_install_extensions": {
    "php": true,
    "html": true,
    "xml": true,
    "r": true,
    "scss": true,
    "toml": true,
    "vue": true,
    "sql": true,
    "rainbow-csv": true,
    "log": true,

    "latex": true,
    "liquid": true,
    "typst": true,
    "mermaid": true,
    "org": true,

    "just": true,
    "make": true,
    "neocmake": true,
    "nix": true,

    "ruby": true,
    "perl": true,
    "lua": true,
    "scheme": true,
    "terraform": true,
    "python-requirements": true,

    "java": true,
    "scala": true,
    "verilog": true,
    "fsharp": true,
    "d": true,
    "csharp": true,
    "haskell": true,

    "dockerfile": true,
    "git-firefly": true,
    "gosum": true,

    "go-snippets": true,
    "javascript-snippets": true,
    "python-snippets": true,

    "tokyo-night": true,
    "solarized": true,
    "catppuccin": true,
    "catppuccin-icons": true,


    "postgres-context-server": true,
  },

  "ui_font_family": "Source Han Mono SC",
  // "buffer_font_family": "Noto Sans Mono CJK SC",
  "buffer_font_family": "Source Han Mono SC",
  // "buffer_font_family": "BlexMono Nerd Font",
  "buffer_font_fallbacks": [
    "Source Han Mono SC",
    "BlexMono Nerd Font",
    "Noto Sans CJK SC",
  ],
}
